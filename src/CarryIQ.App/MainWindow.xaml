<Window x:Class="CarryIQ.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarryIQ.App"
        Title="CarryIQ"
        Width="1366"
        Height="768"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#07111F">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#07111F" />
        <SolidColorBrush x:Key="ShellPanelBrush" Color="#0C1C2D" />
        <SolidColorBrush x:Key="ShellCardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ShellMutedBrush" Color="#9FB2C8" />
        <SolidColorBrush x:Key="ShellTextBrush" Color="#E8EEF5" />
        <SolidColorBrush x:Key="ShellAccentBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="ShellAccentDarkBrush" Color="#16304A" />

        <DataTemplate DataType="{x:Type local:PlaceholderScreenViewModel}">
            <Border Background="{StaticResource ShellCardBrush}"
                    BorderBrush="#D7E2EE"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="28">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="{Binding Summary}"
                               Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="#52606D"
                               TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding Highlights}" Margin="0,24,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Padding="16"
                                        Background="#F8FAFC"
                                        BorderBrush="#D7E2EE"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <TextBlock Text="{Binding}"
                                               FontSize="14"
                                               Foreground="#243B53"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,8,0,0"
                            Padding="16"
                            Background="#EEF6FF"
                            CornerRadius="16">
                        <TextBlock Text="{Binding Footer}"
                                   Foreground="#1D4ED8"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ClubManagerViewModel}">
            <local:ClubManagerView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:SessionManagerViewModel}">
            <local:SessionManagerView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ShotEntryViewModel}">
            <local:ShotEntryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ShotReviewViewModel}">
            <local:ShotReviewView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:AnalyticsViewModel}">
            <local:AnalyticsView />
        </DataTemplate>

        <Style x:Key="ShellNavItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource ShellTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="#0F2236"
                                BorderBrush="#1C3A55"
                                BorderThickness="1"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccentStrip"
                                        Background="Transparent"
                                        CornerRadius="18,0,0,18" />
                                <Grid Grid.Column="1" Margin="18,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ShellTextBrush}" />
                                        <Border x:Name="ActivePill"
                                                Margin="12,0,0,0"
                                                Padding="8,3"
                                                Background="{StaticResource ShellAccentDarkBrush}"
                                                CornerRadius="999"
                                                Visibility="Collapsed">
                                            <TextBlock Text="Active"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ShellAccentBrush}"
                                                       TextWrapping="NoWrap" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               Text="{Binding Summary}"
                                               FontSize="13"
                                               Foreground="{StaticResource ShellMutedBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#16324D" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7DD3FC" />
                                <Setter TargetName="AccentStrip" Property="Background" Value="#7DD3FC" />
                                <Setter TargetName="ActivePill" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#12283F" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#A7F3D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource ShellPanelBrush}"
                Padding="24"
                BorderBrush="#11253B"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="18"
                            Background="{StaticResource ShellAccentBrush}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="CIQ"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#07111F" />
                    </Border>
                    <TextBlock Text="{Binding ApplicationTitle}"
                               Margin="0,18,0,0"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ShellTextBrush}" />
                    <TextBlock Text="{Binding Subtitle}"
                               Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="{StaticResource ShellMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource ShellTextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         KeyboardNavigation.TabNavigation="Continue"
                         ItemContainerStyle="{StaticResource ShellNavItemStyle}" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource ShellBackgroundBrush}">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="24"
                        Background="#0D1E30"
                        BorderBrush="#17324D"
                        BorderThickness="1"
                        CornerRadius="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentScreen.Title}"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ShellTextBrush}" />
                            <TextBlock Text="{Binding CurrentScreen.Summary}"
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       Foreground="{StaticResource ShellMutedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Padding="14,10"
                                Background="#10273F"
                                CornerRadius="16"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Local database"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource ShellAccentBrush}" />
                                <TextBlock Text="{Binding DatabasePath}"
                                           Margin="0,6,0,0"
                                           MaxWidth="360"
                                           FontSize="13"
                                           Foreground="{StaticResource ShellTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Padding="18,14"
                        Background="#F8FAFC"
                        BorderBrush="#D7E2EE"
                        BorderThickness="1"
                        CornerRadius="18">
                    <TextBlock Text="{Binding CurrentScreen.Footer}"
                               FontSize="13"
                               Foreground="#334E68"
                               TextWrapping="Wrap" />
                </Border>

                <ContentControl Grid.Row="2"
                                Content="{Binding CurrentScreen}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
