<UserControl x:Class="CarryIQ.App.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CarryIQ.App"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="16" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                Padding="24">
            <StackPanel>
                <TextBlock Text="Performance dashboard"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="{Binding Summary}"
                           Margin="0,6,0,0"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Grid Margin="0,18,0,0">
                    <ItemsControl ItemsSource="{Binding MetricCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,14,14"
                                        Padding="16"
                                        Background="#F8FAFC"
                                        BorderBrush="#D9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#627D98" />
                                        <TextBlock Text="{Binding ValueText}"
                                                   Margin="0,8,0,0"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Foreground="#102A43" />
                                        <TextBlock Text="{Binding DetailText}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#52606D"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Background="#FFFFFF"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                    <TextBlock Text="Recent sessions"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="Select a session in the grid to inspect its carry summary."
                               Margin="0,4,0,0"
                               Foreground="#627D98"
                               TextWrapping="Wrap" />
                </StackPanel>

                <DataGrid ItemsSource="{Binding RecentSessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="White"
                          BorderBrush="#D9E2EC"
                          BorderThickness="1"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding SessionDateText}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Shots" Binding="{Binding ShotCountText}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Avg carry" Binding="{Binding AverageCarryText}" Width="110" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,18,0">
                    <TextBlock Text="Selected session"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="{Binding SelectedSession.Name}"
                               Margin="0,6,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243B53" />
                    <TextBlock Text="{Binding SelectedSession.SessionDateText}"
                               Margin="0,4,0,0"
                               Foreground="#627D98" />

                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,12,12" Padding="14" Background="#F8FAFC" BorderBrush="#D9E2EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Included shots" Foreground="#627D98" />
                                <TextBlock Text="{Binding SelectedSession.IncludedShotCount}" FontSize="24" FontWeight="SemiBold" Foreground="#102A43" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="0,0,0,12" Padding="14" Background="#F8FAFC" BorderBrush="#D9E2EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Average carry" Foreground="#627D98" />
                                <TextBlock Text="{Binding SelectedSession.AverageCarryText}" FontSize="24" FontWeight="SemiBold" Foreground="#102A43" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Margin="0,0,12,0" Padding="14" Background="#F8FAFC" BorderBrush="#D9E2EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Total shots" Foreground="#627D98" />
                                <TextBlock Text="{Binding SelectedSession.TotalShots}" FontSize="24" FontWeight="SemiBold" Foreground="#102A43" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" Padding="14" Background="#F8FAFC" BorderBrush="#D9E2EC" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Inclusion ratio" Foreground="#627D98" />
                                <TextBlock>
                                    <Run Text="{Binding SelectedSession.IncludedShotCount}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding SelectedSession.TotalShots}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Notes"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="{Binding Footer}"
                               Margin="0,6,0,0"
                               Foreground="#627D98"
                               TextWrapping="Wrap" />
                    <Border Margin="0,18,0,0"
                            Padding="14"
                            Background="#EEF6FF"
                            BorderBrush="#CFE3FF"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Status" Foreground="#1D4ED8" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,6,0,0"
                                       Foreground="#1E3A8A"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Margin="0,8,0,0"
                                       Foreground="#B91C1C"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,8"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
