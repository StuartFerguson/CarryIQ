<UserControl x:Class="CarryIQ.App.ShotReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CarryIQ.App"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#C9D6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#C9D6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D9E2EC"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Shot review"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="Use the grid to review, select, and bulk-correct recent shots without leaving the keyboard."
                           Margin="0,6,0,0"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Border Margin="0,16,0,0"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#334E68"
                               TextWrapping="Wrap" />
                </Border>

                <UniformGrid Columns="3" Margin="0,16,0,0">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Session" Foreground="#334E68" />
                        <ComboBox ItemsSource="{Binding Sessions}"
                                  SelectedValue="{Binding SelectedSessionId, Mode=TwoWay}"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#102A43">
                                        <Run Text="{Binding SessionDate, StringFormat={}{0:yyyy-MM-dd}}" />
                                        <Run Text="  " />
                                        <Run Text="{Binding Name}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Search" Foreground="#334E68" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Filters" Foreground="#334E68" />
                        <CheckBox Content="Included only" IsChecked="{Binding IncludedOnly}" Margin="0,8,0,0" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,8" Margin="0,0,8,0" />
                    <Button Content="Include selected" Command="{Binding IncludeSelectedCommand}" Padding="14,8" Margin="0,0,8,0" />
                    <Button Content="Exclude selected" Command="{Binding ExcludeSelectedCommand}" Padding="14,8" Margin="0,0,8,0" />
                    <Button Content="Apply club" Command="{Binding ApplyClubCommand}" Padding="14,8" Margin="0,0,8,0" />
                    <Button Content="Apply swing type" Command="{Binding ApplySwingTypeCommand}" Padding="14,8" />
                </StackPanel>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.2*" />
                    <RowDefinition Height="1.3*" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding Shots}"
                          SelectedItem="{Binding SelectedShot, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="White"
                          BorderBrush="#D9E2EC"
                          BorderThickness="1"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="48" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="#" Binding="{Binding ShotSequence}" Width="60" IsReadOnly="True" />
                        <DataGridTextColumn Header="Recorded" Binding="{Binding RecordedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="160" IsReadOnly="True" />
                        <DataGridTextColumn Header="Club" Binding="{Binding ClubName}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Carry" Binding="{Binding DisplayCarryDistance}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="State" Binding="{Binding InclusionState}" Width="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="Swing" Binding="{Binding SwingType}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="18"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="Selected shot" FontWeight="SemiBold" Foreground="#102A43" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedShot.Notes}" Foreground="#334E68" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding SelectedShot.RawImportData}" Foreground="#627D98" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bulk edit" FontWeight="SemiBold" Foreground="#102A43" />
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Club" Foreground="#334E68" />
                                <ComboBox ItemsSource="{Binding Clubs}"
                                          SelectedValue="{Binding SelectedClubId, Mode=TwoWay}"
                                          SelectedValuePath="Id">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Swing type" Foreground="#334E68" />
                                <ComboBox ItemsSource="{Binding SwingTypeOptions}"
                                          DisplayMemberPath="DisplayText"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedSwingType, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
