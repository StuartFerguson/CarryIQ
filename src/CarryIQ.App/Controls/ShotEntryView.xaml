<UserControl x:Class="CarryIQ.App.ShotEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#C9D6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#DC2626" />
                    <Setter Property="Background" Value="#FFF5F5" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#C9D6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D9E2EC"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Manual entry"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="Keep your hands on the keyboard. Choose the session and club once, then tab through the shot inputs and press Enter to save."
                           Margin="0,6,0,16"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Border Margin="0,0,0,16"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Status" FontWeight="SemiBold" Foreground="#102A43" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,6,0,0"
                                   Foreground="#334E68"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <UniformGrid Columns="2" Margin="0,0,0,16">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Practice session" Foreground="#334E68" />
                        <ComboBox ItemsSource="{Binding Sessions}"
                                  SelectedValue="{Binding SelectedSessionId, Mode=TwoWay}"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="#102A43">
                                            <Run Text="{Binding SessionDate, StringFormat={}{0:yyyy-MM-dd}}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Name}" />
                                        </TextBlock>
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="#627D98"
                                                   Text="{Binding LocationName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Club" Foreground="#334E68" />
                        <ComboBox ItemsSource="{Binding Clubs}"
                                  SelectedValue="{Binding SelectedClubId, Mode=TwoWay}"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="#102A43" Text="{Binding Name}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="#627D98"
                                                   Text="{Binding ClubType}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,16">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Carry (yards)" Foreground="#334E68" />
                        <TextBox Text="{Binding CarryDistanceText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Total (yards)" Foreground="#334E68" />
                        <TextBox Text="{Binding TotalDistanceText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Ball speed (mph)" Foreground="#334E68" />
                        <TextBox Text="{Binding BallSpeedText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Club speed (mph)" Foreground="#334E68" />
                        <TextBox Text="{Binding ClubSpeedText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Launch angle" Foreground="#334E68" />
                        <TextBox Text="{Binding LaunchAngleText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Launch direction" Foreground="#334E68" />
                        <TextBox Text="{Binding LaunchDirectionText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Notes" Foreground="#334E68" />
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="96"
                             TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save shot"
                            Command="{Binding SaveCommand}"
                            IsDefault="True"
                            Padding="16,8"
                            Margin="0,0,10,0" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#627D98"
                               Text="Enter saves the current shot." />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
