<UserControl x:Class="CarryIQ.App.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Border Background="#FFFFFF"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Utilities"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#102A43" />
                    <TextBlock Text="{Binding Summary}"
                               Margin="0,6,0,0"
                               Foreground="#627D98"
                               TextWrapping="Wrap" />

                    <Border Margin="0,20,0,0"
                            Padding="18"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Seed demo data"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#102A43" />
                            <TextBlock Text="Generate practice sessions and shots for local dashboard testing. If the bag is empty, the utility creates a starter set of clubs first."
                                       Margin="0,6,0,0"
                                       Foreground="#627D98"
                                       TextWrapping="Wrap" />

                            <UniformGrid Columns="2" Margin="0,16,0,0">
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="Session count" Foreground="#334E68" />
                                    <TextBox Text="{Binding SessionCountText, UpdateSourceTrigger=PropertyChanged}" Padding="12,8" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Weeks" Foreground="#334E68" />
                                    <TextBox Text="{Binding WeekSpanText, UpdateSourceTrigger=PropertyChanged}" Padding="12,8" />
                                </StackPanel>
                            </UniformGrid>

                            <Button Content="Seed demo data"
                                    Command="{Binding SeedDemoDataCommand}"
                                    Padding="16,8"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0" />

                            <Border Margin="0,16,0,0"
                                    Padding="14"
                                    Background="#EEF6FF"
                                    BorderBrush="#CFE3FF"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="Status" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Margin="0,6,0,0"
                                               Foreground="#1E3A8A"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Margin="0,8,0,0"
                                               Foreground="#B91C1C"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0"
                            Padding="18"
                            Background="#FFFFFF"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="Future tools"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#102A43" />
                            <TextBlock Text="This page is the home for local maintenance actions, dataset generators, and other developer shortcuts."
                                       Margin="0,6,0,0"
                                       Foreground="#627D98"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding Footer}"
                               Margin="0,18,0,0"
                               Foreground="#627D98"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
