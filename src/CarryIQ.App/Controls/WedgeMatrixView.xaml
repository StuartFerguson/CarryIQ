<UserControl x:Class="CarryIQ.App.WedgeMatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D9E2EC"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Wedge matrix"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="Read the wedge references for A1, A2, and A3. Missing cells remain N/A in phase 1."
                           Margin="0,6,0,0"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Border Margin="0,16,0,0"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Include inactive wedges"
                                      IsChecked="{Binding IncludeInactive, Mode=TwoWay}" />
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Padding="14,8"
                                    Margin="16,0,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#334E68" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ErrorMessage}" Margin="0,6,0,0" Foreground="#B91C1C" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      IsReadOnly="True"
                      Background="White"
                      BorderBrush="#D9E2EC"
                      BorderThickness="1"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Club" Binding="{Binding ClubName}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding ClubType}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                    <DataGridTemplateColumn Header="A1" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="A1" FontWeight="SemiBold" Foreground="#102A43" />
                                        <TextBlock Text="{Binding A1.TargetDistanceText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A1.AverageCarryText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A1.SampleSizeText}" Foreground="#627D98" />
                                        <TextBlock Text="{Binding A1.StandardDeviationText}" Foreground="#627D98" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="A2" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="A2" FontWeight="SemiBold" Foreground="#102A43" />
                                        <TextBlock Text="{Binding A2.TargetDistanceText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A2.AverageCarryText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A2.SampleSizeText}" Foreground="#627D98" />
                                        <TextBlock Text="{Binding A2.StandardDeviationText}" Foreground="#627D98" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="A3" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="A3" FontWeight="SemiBold" Foreground="#102A43" />
                                        <TextBlock Text="{Binding A3.TargetDistanceText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A3.AverageCarryText}" Foreground="#334E68" />
                                        <TextBlock Text="{Binding A3.SampleSizeText}" Foreground="#627D98" />
                                        <TextBlock Text="{Binding A3.StandardDeviationText}" Foreground="#627D98" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
