<UserControl x:Class="CarryIQ.App.WedgeMatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CarryIQ.App"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="WedgeCellBadgeStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsManualOverride}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type local:WedgeMatrixRowEditorViewModel}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ClubName}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#102A43" />
                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,6,0,0"
                                   Foreground="#627D98" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Save references"
                            Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Padding="14,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top" />
                </Grid>

                <UniformGrid Columns="3">
                    <Border Margin="0,0,12,0"
                            Padding="14"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="{Binding A1.SetupType}" FontWeight="SemiBold" Foreground="#102A43" />
                            <TextBox Text="{Binding A1.TargetDistanceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A1.AverageCarryText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A1.StandardDeviationText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A1.SampleSizeText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,12,0"
                            Padding="14"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="{Binding A2.SetupType}" FontWeight="SemiBold" Foreground="#102A43" />
                            <TextBox Text="{Binding A2.TargetDistanceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,8" />
                            <TextBox Text="{Binding A2.AverageCarryText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A2.StandardDeviationText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A2.SampleSizeText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Padding="14"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock Text="{Binding A3.SetupType}" FontWeight="SemiBold" Foreground="#102A43" />
                            <TextBox Text="{Binding A3.TargetDistanceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,8" />
                            <TextBox Text="{Binding A3.AverageCarryText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A3.StandardDeviationText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBox Text="{Binding A3.SampleSizeText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D9E2EC"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Wedge matrix"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="Read the wedge references for A1, A2, and A3. Select a wedge to edit its detailed overrides."
                           Margin="0,6,0,0"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Border Margin="0,16,0,0"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Include inactive wedges"
                                      IsChecked="{Binding IncludeInactive, Mode=TwoWay}" />
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Padding="14,8"
                                    Margin="16,0,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#334E68" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ErrorMessage}" Margin="0,6,0,0" Foreground="#B91C1C" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="White"
                          BorderBrush="#D9E2EC"
                          BorderThickness="1"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Club" Binding="{Binding ClubName}" Width="*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding ClubType}" Width="120" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                        <DataGridTemplateColumn Header="A1" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            Background="#FFFFFF"
                                            BorderBrush="#E2E8F0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding A1.SetupLabel}" FontWeight="SemiBold" Foreground="#102A43" />
                                                <TextBlock Text="{Binding A1.OverrideText}"
                                                           Margin="10,0,0,0"
                                                           Style="{StaticResource WedgeCellBadgeStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding A1.TargetDistanceText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A1.AverageCarryText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A1.SampleSizeText}" Foreground="#627D98" />
                                            <TextBlock Text="{Binding A1.StandardDeviationText}" Foreground="#627D98" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="A2" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            Background="#FFFFFF"
                                            BorderBrush="#E2E8F0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding A2.SetupLabel}" FontWeight="SemiBold" Foreground="#102A43" />
                                                <TextBlock Text="{Binding A2.OverrideText}"
                                                           Margin="10,0,0,0"
                                                           Style="{StaticResource WedgeCellBadgeStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding A2.TargetDistanceText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A2.AverageCarryText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A2.SampleSizeText}" Foreground="#627D98" />
                                            <TextBlock Text="{Binding A2.StandardDeviationText}" Foreground="#627D98" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="A3" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            Background="#FFFFFF"
                                            BorderBrush="#E2E8F0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding A3.SetupLabel}" FontWeight="SemiBold" Foreground="#102A43" />
                                                <TextBlock Text="{Binding A3.OverrideText}"
                                                           Margin="10,0,0,0"
                                                           Style="{StaticResource WedgeCellBadgeStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding A3.TargetDistanceText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A3.AverageCarryText}" Foreground="#334E68" />
                                            <TextBlock Text="{Binding A3.SampleSizeText}" Foreground="#627D98" />
                                            <TextBlock Text="{Binding A3.StandardDeviationText}" Foreground="#627D98" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="#F8FAFC"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <ContentControl Content="{Binding SelectedRowEditor}" />
                        <TextBlock Text="Select a wedge row above to edit its detailed references."
                                   Foreground="#627D98"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRowEditor}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
