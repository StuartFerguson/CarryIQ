<UserControl x:Class="CarryIQ.App.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#C9D6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#D9E2EC"
            BorderThickness="1"
            CornerRadius="18"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2.1*" />
                <RowDefinition Height="1.2*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Club gapping"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#102A43" />
                <TextBlock Text="Review included shots by club, switch between mean and median gaps, and inspect spacing issues from a single master-detail view."
                           Margin="0,6,0,0"
                           Foreground="#627D98"
                           TextWrapping="Wrap" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Text="Gap mode" Foreground="#334E68" />
                        <ComboBox ItemsSource="{Binding GapOptions}"
                                  DisplayMemberPath="DisplayText"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedGapOption, Mode=TwoWay}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,8"
                            Margin="0,24,0,12" />

                    <StackPanel Grid.Column="2" Margin="16,24,0,12" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#334E68"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Margin="0,6,0,0"
                                   Foreground="#B91C1C"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="White"
                      BorderBrush="#D9E2EC"
                      BorderThickness="1"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      Margin="0,0,0,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Club" Binding="{Binding ClubName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Type" Binding="{Binding ClubType}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Shots" Binding="{Binding SampleCount}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Mean" Binding="{Binding MeanCarryYards, StringFormat={}{0:0.#}}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Median" Binding="{Binding MedianCarryYards, StringFormat={}{0:0.#}}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Carry" Binding="{Binding RepresentativeCarryYards, StringFormat={}{0:0.#}}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Consist." Binding="{Binding ConsistencyScore, StringFormat={}{0:0.#}}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn Header="Gap" Binding="{Binding GapToNextYards, StringFormat={}{0:0.#}}" Width="80" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding GapStatusText}" Width="120" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Selected club"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#102A43" />
                        <TextBlock Text="{Binding SelectedRow.ClubName}"
                                   Margin="0,4,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#243B53" />
                        <TextBlock Text="{Binding SelectedRow.SampleWarningText}"
                                   Margin="0,6,0,0"
                                   Foreground="#B45309"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedRow.GapStatusText}"
                                   Margin="0,4,0,0"
                                   Foreground="#334E68"
                                   TextWrapping="Wrap" />

                        <UniformGrid Columns="4" Margin="0,16,0,0">
                            <Border Margin="0,0,12,12" Padding="12" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="Mean carry" Foreground="#627D98" />
                                    <TextBlock Text="{Binding SelectedRow.MeanCarryYards, StringFormat={}{0:0.#}}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#102A43" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,12,12" Padding="12" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="Median carry" Foreground="#627D98" />
                                    <TextBlock Text="{Binding SelectedRow.MedianCarryYards, StringFormat={}{0:0.#}}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#102A43" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,12,12" Padding="12" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="Consistency" Foreground="#627D98" />
                                    <TextBlock Text="{Binding SelectedRow.ConsistencyScore, StringFormat={}{0:0.#}}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#102A43" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,12" Padding="12" Background="White" BorderBrush="#D7E2EE" BorderThickness="1" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Text="Gap to next" Foreground="#627D98" />
                                    <TextBlock Text="{Binding SelectedRow.GapToNextYards, StringFormat={}{0:0.#}}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#102A43" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
